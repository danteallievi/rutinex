{
  "name": "rutinex",
  "version": "0.0.0",
  "private": true,
  "description": "Rutinex — plataforma SaaS multi-tenant para gimnasios y personal trainers.",
  "engines": {
    "node": ">=22 <23",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.9.0",
  "scripts": {
    "api:dev": "pnpm --filter @rutinex/api start:dev",
    "web:dev": "pnpm --filter @rutinex/web dev",
    "build": "pnpm -r build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "@nestjs/core",
      "@tailwindcss/oxide",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-next": "15.5.18",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.59.3"
  }
}
