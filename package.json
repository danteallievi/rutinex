{
  "name": "rutinex",
  "version": "0.0.0",
  "private": true,
  "description": "Rutinex — plataforma SaaS multi-tenant para gimnasios y personal trainers.",
  "engines": {
    "node": ">=22 <23",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.9.0",
  "scripts": {
    "api:dev": "pnpm --filter @rutinex/api start:dev",
    "web:dev": "pnpm --filter @rutinex/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "@nestjs/core",
      "@tailwindcss/oxide",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
