{
  "name": "@rutinex/shared-types",
  "version": "0.0.0",
  "private": true,
  "description": "Tipos y enums compartidos entre @rutinex/api y @rutinex/web. Solo tipos, sin lógica.",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "typescript": "^5"
  }
}
