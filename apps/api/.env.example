# Puerto del API en dev. Web usa 3000 (Next default), api usa 3001.
PORT=3001

# Postgres local (lo levanta `pnpm db:up` en la raíz; ver docker-compose.yml).
# En prod, esta misma var apunta al managed DB (Neon, etc.).
DATABASE_URL=postgres://rutinex:rutinex@localhost:5432/rutinex

# Si lo seteás en `true`, TypeORM logguea las queries en stdout.
DATABASE_LOGGING=false

# Secret para firmar los access JWT (HS256, TTL 15min). Generá uno largo y
# aleatorio: `openssl rand -base64 48`. Rotarlo invalida todos los access
# tokens vivos (aceptable: el access dura 15min). Nunca commitearlo.
JWT_ACCESS_SECRET=replace-me-with-a-long-random-secret
