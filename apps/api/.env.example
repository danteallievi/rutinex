# Puerto del API en dev. Web usa 3000 (Next default), api usa 3001.
PORT=3001

# Postgres local (lo levanta `pnpm db:up` en la raíz; ver docker-compose.yml).
# En prod, esta misma var apunta al managed DB (Neon, etc.).
DATABASE_URL=postgres://rutinex:rutinex@localhost:5432/rutinex

# Si lo seteás en `true`, TypeORM logguea las queries en stdout.
DATABASE_LOGGING=false

# Secret para firmar los access JWT (HS256, TTL 15min). Generá uno largo y
# aleatorio: `openssl rand -base64 48`. Rotarlo invalida todos los access
# tokens vivos (aceptable: el access dura 15min). Nunca commitearlo.
JWT_ACCESS_SECRET=replace-me-with-a-long-random-secret

# Dominio de la cookie httpOnly `rutinex_refresh` (Step 9, ver ADR-017). En
# prod típicamente `.rutinex.app` (con punto inicial) para que la cookie sea
# accesible desde `<slug>.rutinex.app` y `superadmin.rutinex.app`. En dev,
# dejá la var vacía: la cookie aplica al subdominio actual y alcanza para
# probar manualmente.
REFRESH_COOKIE_DOMAIN=

# Cloudflare R2 — storage de media (Step 15, ver ADR-004 + ADR-023).
# - Account ID: lo encontrás en el dashboard de Cloudflare (URL del panel R2).
# - Access key + secret: creados en R2 → "Manage R2 API Tokens" con permiso
#   Object Read+Write sobre el bucket de Rutinex. Nunca commitearlos.
# - Bucket: el bucket dedicado al entorno (`rutinex-media-dev`,
#   `rutinex-media-prod`, etc.). Cada entorno usa su propio bucket.
# - Public URL: base del dominio público del bucket (acceso público de lectura
#   habilitado en R2 — ver ADR-023). Se concatena con la key para construir el
#   `mediaUrl` final que persiste el API en `exercises.media_url`. Sin barra
#   final. Ej: `https://media-dev.rutinex.app` o el dominio gestionado de R2
#   `https://pub-<hash>.r2.dev`.
# - Presign TTL: vida útil de la URL firmada del PUT (default 300s = 5min).
# En dev, dejá todo vacío si no vas a probar uploads reales; el endpoint
# devolverá 503 cuando alguien lo invoque sin config.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=
R2_PRESIGN_TTL_SECONDS=300
