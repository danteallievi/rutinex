# URL del API. En dev levantamos NestJS en 3001 (ver apps/api/.env.example).
# En prod va a ser https://api.rutinex.app.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Dominio raíz para construir links a subdominios de tenant. En dev usamos
# `localhost:3000` (los browsers resuelven *.localhost automáticamente).
NEXT_PUBLIC_ROOT_HOST=localhost:3000
